<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <meta name="path" content={Dashboard.Endpoint.struct_url().path} />
    <.live_title default={Scouter.name()}>
      {assigns[:page_title]}
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/dashboard.css"} />
    <link phx-track-static rel="stylesheet" href={~p"/css/meter.css"} />
    <link phx-track-static rel="stylesheet" href={~p"/css/inputs.css"} />
    <script phx-track-static defer src={~p"/js/phoenix_html.js"}>
    </script>
    <.import_map />
    <script phx-track-static defer type="module" src={~p"/js/dashboard.js"}>
    </script>
    <script phx-track-static defer type="module" src={~p"/js/arrow.js"}>
    </script>

    <.development_scripts conn={@conn} />

    <.stylesheets :if={@environment == :trusted} headers={@conn.req_headers} />
  </head>
  <body class="font-mono text-sm bg-zinc-100/30">
    {@inner_content}
  </body>
</html>
